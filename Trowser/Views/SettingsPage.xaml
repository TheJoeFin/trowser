<Page
    x:Class="Trowser.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="using:Trowser.Helpers"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Trowser.Core.Models"
    mc:Ignorable="d">
    <Page.Resources>
        <helpers:EnumToBooleanConverter x:Key="EnumToBooleanConverter" />
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Main content  -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  Browser list  -->
            <Grid Grid.Column="0" Margin="0,0,12,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock
                    Grid.Row="0"
                    Margin="0,0,0,8"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Text="Tray Browsers" />

                <ListView
                    x:Name="BrowserListView"
                    Grid.Row="1"
                    ItemsSource="{x:Bind ViewModel.Browsers, Mode=OneWay}"
                    SelectedItem="{x:Bind ViewModel.SelectedBrowser, Mode=TwoWay}"
                    SelectionMode="Single">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:TrayBrowserConfig">
                            <StackPanel Padding="4">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock FontWeight="SemiBold" Text="{x:Bind Name}" />
                                    <Border
                                        Padding="4,1"
                                        VerticalAlignment="Center"
                                        CornerRadius="4"
                                        Visibility="{x:Bind IsHidden, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock
                                            FontSize="10"
                                            Foreground="Orange"
                                            Text="hidden" />
                                    </Border>
                                </StackPanel>
                                <TextBlock
                                    FontSize="12"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="{x:Bind Url}"
                                    TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <StackPanel
                    Grid.Row="2"
                    Margin="0,8,0,0"
                    Orientation="Horizontal"
                    Spacing="8">
                    <Button Command="{x:Bind ViewModel.StartAddCommand}" Content="Add New" />
                    <Button Command="{x:Bind ViewModel.StartEditCommand}" Content="Edit" />
                    <Button Command="{x:Bind ViewModel.ToggleHideBrowserCommand}" Content="{x:Bind ViewModel.HideToggleLabel, Mode=OneWay}" />
                    <Button
                        Command="{x:Bind ViewModel.DeleteBrowserCommand}"
                        Content="Delete"
                        Foreground="Red" />
                </StackPanel>
            </Grid>

            <!--  Edit form  -->
            <StackPanel
                Grid.Column="1"
                Margin="12,0,0,0"
                Spacing="12"
                Visibility="{x:Bind ViewModel.IsEditing, Mode=OneWay}">

                <TextBlock
                    FontSize="16"
                    FontWeight="SemiBold"
                    Text="Browser Details" />

                <TextBox
                    Header="Name"
                    PlaceholderText="My Website"
                    Text="{x:Bind ViewModel.EditName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <TextBox
                    Header="URL"
                    PlaceholderText="https://example.com"
                    Text="{x:Bind ViewModel.EditUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <StackPanel Spacing="4">
                    <TextBlock Text="Icon" />
                    <RadioButton
                        Checked="FetchFaviconRadioButton_Checked"
                        Content="Fetch from website"
                        GroupName="IconMode"
                        IsChecked="{x:Bind ViewModel.IsIconModeFetchFavicon, Mode=OneWay}" />
                    <RadioButton
                        Checked="CustomIconRadioButton_Checked"
                        Content="Custom .ico file"
                        GroupName="IconMode"
                        IsChecked="{x:Bind ViewModel.IsIconModeCustomFile, Mode=OneWay}" />
                </StackPanel>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox
                        Grid.Column="0"
                        Header="Icon Path"
                        PlaceholderText="C:\path\to\icon.ico"
                        Text="{x:Bind ViewModel.EditIconPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <Button
                        x:Name="BrowseIconButton"
                        Grid.Column="1"
                        Margin="8,0,0,0"
                        VerticalAlignment="Bottom"
                        Click="BrowseIconButton_Click"
                        Content="Browse..." />
                </Grid>

                <StackPanel
                    Margin="0,8,0,0"
                    Orientation="Horizontal"
                    Spacing="8">
                    <Button
                        Command="{x:Bind ViewModel.SaveBrowserCommand}"
                        Content="Save"
                        Style="{ThemeResource AccentButtonStyle}" />
                    <Button Command="{x:Bind ViewModel.CancelEditCommand}" Content="Cancel" />
                </StackPanel>
            </StackPanel>
        </Grid>

        <!--  Theme selector  -->
        <StackPanel Grid.Row="1" Margin="0,16,0,0">
            <TextBlock
                FontSize="16"
                FontWeight="SemiBold"
                Text="Personalization" />
            <StackPanel
                Margin="0,8,0,0"
                Orientation="Horizontal"
                Spacing="12">
                <RadioButton
                    Command="{x:Bind ViewModel.SwitchThemeCommand}"
                    CommandParameter="Light"
                    Content="Light"
                    GroupName="AppTheme"
                    IsChecked="{x:Bind ViewModel.ElementTheme, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Light, Mode=OneWay}" />
                <RadioButton
                    Command="{x:Bind ViewModel.SwitchThemeCommand}"
                    CommandParameter="Dark"
                    Content="Dark"
                    GroupName="AppTheme"
                    IsChecked="{x:Bind ViewModel.ElementTheme, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Dark, Mode=OneWay}" />
                <RadioButton
                    Command="{x:Bind ViewModel.SwitchThemeCommand}"
                    CommandParameter="Default"
                    Content="System Default"
                    GroupName="AppTheme"
                    IsChecked="{x:Bind ViewModel.ElementTheme, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Default, Mode=OneWay}" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>
